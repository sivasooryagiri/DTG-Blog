---
import interWoff2 from '@fontsource-variable/inter/files/inter-latin-wght-normal.woff2?url';
import newsreaderWoff2 from '@fontsource-variable/newsreader/files/newsreader-latin-wght-normal.woff2?url';
import { getImage } from 'astro:assets';
import siteConfig from '../data/site-config';
import type { ImageInput } from '../types';

import '../styles/global.css';

export type Props = {
    title?: string;
    description?: string;
    image?: ImageInput | undefined;
    pageType?: 'website' | 'article';
};

const { description = siteConfig.description, pageType = 'website' } = Astro.props;
const title = [Astro.props.title, siteConfig.seoTitle ?? siteConfig.title].filter(Boolean).join(' | ');
const image = Astro.props.image ?? siteConfig.image;
const personName = siteConfig.personName ?? siteConfig.title;
const brandName = siteConfig.brandName ?? siteConfig.title;
const keywords = siteConfig.keywords?.join(', ');
const sameAs = siteConfig.socialLinks?.map((link) => link.href) ?? [];
const personAlternateNames = Array.from(
    new Set([brandName, ...(siteConfig.alternateNames ?? [])].filter((name) => Boolean(name) && name !== personName))
);
const brandAlternateNames = Array.from(
    new Set([personName, ...(siteConfig.alternateNames ?? [])].filter((name) => Boolean(name) && name !== brandName))
);
let resolvedImage: { src: string; alt?: string } | undefined;
if (image?.src) {
    if (typeof image.src === 'string') {
        resolvedImage = {
            src: new URL(image.src, Astro.site).toString(),
            alt: image.alt
        };
    } else {
        const optimizedImage = await getImage({
            src: image.src as ImageMetadata,
            width: 1200,
            height: 630,
            format: 'jpeg',
            fit: 'cover'
        });
        resolvedImage = {
            src: new URL(optimizedImage.src, Astro.site).toString(),
            alt: image.alt
        };
    }
}
const canonicalURL = new URL(Astro.request.url, Astro.site);
const canonicalUrlString = formatCanonicalURL(canonicalURL);
const websiteBaseUrl = formatCanonicalURL(siteConfig.website);
const personStructuredData = {
    '@context': 'https://schema.org',
    '@type': 'Person',
    '@id': `${websiteBaseUrl}#person`,
    name: personName,
    alternateName: personAlternateNames,
    url: websiteBaseUrl,
    sameAs
};
const organizationStructuredData = {
    '@context': 'https://schema.org',
    '@type': 'Organization',
    '@id': `${websiteBaseUrl}#organization`,
    name: brandName,
    alternateName: brandAlternateNames,
    url: websiteBaseUrl,
    sameAs
};
const websiteStructuredData = {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    '@id': `${websiteBaseUrl}#website`,
    name: brandName,
    alternateName: Array.from(new Set([personName, ...(siteConfig.alternateNames ?? [])])),
    url: websiteBaseUrl,
    publisher: { '@id': `${websiteBaseUrl}#organization` }
};

/**
 * Enforce some standard canonical URL formatting across the site.
 */
function formatCanonicalURL(url: string | URL) {
    let path = url.toString();
    const hasQueryParams = path.includes('?');
    path = path.replace(/\/?$/, hasQueryParams ? '' : '/');
    return path;
}
---

<!-- High Priority Global Metadata -->
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<title>{title}</title>
<meta name="generator" content={Astro.generator} />
<meta name="author" content={personName} />
{keywords && <meta name="keywords" content={keywords} />}

<!-- Fonts -->
<link rel="preload" as="font" type="font/woff2" href={interWoff2} crossorigin="anonymous" />
<link rel="preload" as="font" type="font/woff2" href={newsreaderWoff2} crossorigin="anonymous" />

<!-- Low Priority Global Metadata -->
<link rel="icon" href="/favicon.ico" sizes="any" />
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<link rel="icon" type="image/png" sizes="48x48" href="/favicon-48x48.png" />
<link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
<link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
<link rel="manifest" href="/site.webmanifest" />
<link rel="sitemap" href="/sitemap-index.xml" />
<link rel="alternate" type="application/rss+xml" href="/rss.xml" title="RSS" />
<script type="application/ld+json" set:html={JSON.stringify(personStructuredData)} />
<script type="application/ld+json" set:html={JSON.stringify(organizationStructuredData)} />
<script type="application/ld+json" set:html={JSON.stringify(websiteStructuredData)} />

<!-- Page Metadata -->
<link rel="canonical" href={canonicalUrlString} />
<meta name="description" content={description} />

<!-- Open Graph / Facebook -->
<meta property="og:type" content={pageType} />
<meta property="og:url" content={canonicalUrlString} />
<meta property="og:site_name" content={brandName} />
<meta property="og:title" content={title} />
{description && <meta property="og:description" content={description} />}
{resolvedImage?.src && <meta property="og:image" content={resolvedImage.src} />}
{resolvedImage?.alt && <meta property="og:image:alt" content={resolvedImage.alt} />}

<!-- X/Twitter -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:url" content={canonicalUrlString} />
<meta name="twitter:title" content={title} />
{description && <meta name="twitter:description" content={description} />}
{resolvedImage?.src && <meta name="twitter:image" content={resolvedImage.src} />}
{resolvedImage?.alt && <meta name="twitter:image:alt" content={resolvedImage.alt} />}
